{
  "name": "mina-live",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/mina-live/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-wasm": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/mina-live",
        "commands": [
          "yarn wasm-pack build ./src-rust --target bundler",
          "npx rimraf src-rust/pkg/.gitignore"
        ],
        "parallel": false
      }
    },
    "build-wasm-debug": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/mina-live",
        "commands": [
          "yarn wasm-pack build --debug ./src-rust --target bundler",
          "npx rimraf src-rust/pkg/.gitignore"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/mina-live/**/*.{ts,tsx,js,jsx}"],
        "ignorePath": "libs/mina-live/.eslintignore"
      }
    }
  }
}
